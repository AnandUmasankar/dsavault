---
interface Props {
  difficulty: 'Easy' | 'Medium' | 'Hard';
}

const { difficulty } = Astro.props;

const colorMap = {
  Easy: 'bg-vault-easy/20 text-vault-easy',
  Medium: 'bg-vault-medium/20 text-vault-medium',
  Hard: 'bg-vault-hard/20 text-vault-hard',
} as const;
---

<span class={`inline-block px-2.5 py-0.5 rounded-full text-xs font-semibold ${colorMap[difficulty]}`}>
  {difficulty}
</span>
