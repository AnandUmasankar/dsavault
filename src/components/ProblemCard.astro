---
import DifficultyBadge from './DifficultyBadge.astro';
import { toSlug } from '../utils/slug';

interface Props {
  number: number;
  title: string;
  slug: string;
  difficulty: 'Easy' | 'Medium' | 'Hard';
  tags: string[];
  companies: string[];
}

const { number, title, slug, difficulty, tags, companies } = Astro.props;
---

<a href={`/problems/${slug}/`} class="block bg-vault-surface hover:bg-vault-surface-hover border border-vault-border rounded-lg p-4 transition-colors">
  <div class="flex items-start justify-between gap-3 mb-2">
    <h3 class="text-vault-text font-semibold text-sm">
      <span class="text-vault-muted">#{number}</span> {title}
    </h3>
    <DifficultyBadge difficulty={difficulty} />
  </div>
  <div class="flex flex-wrap gap-1.5 mb-2">
    {tags.map((tag) => (
      <span class="text-xs px-2 py-0.5 rounded bg-vault-primary/10 text-vault-primary">
        {tag}
      </span>
    ))}
  </div>
  {companies.length > 0 && (
    <div class="flex flex-wrap gap-1.5">
      {companies.slice(0, 3).map((company) => (
        <span class="text-xs text-vault-muted">
          {company}
        </span>
      ))}
      {companies.length > 3 && (
        <span class="text-xs text-vault-muted">+{companies.length - 3} more</span>
      )}
    </div>
  )}
</a>
