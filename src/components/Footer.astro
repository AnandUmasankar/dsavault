---
const currentYear = new Date().getFullYear();
const footerLinks = [
  { href: '/about/', label: 'About' },
  { href: '/privacy-policy/', label: 'Privacy Policy' },
  { href: '/contact/', label: 'Contact' },
];
---

<footer class="bg-vault-surface border-t border-vault-border mt-auto">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-vault-muted text-sm">
        &copy; {currentYear} DSA Vault. All rights reserved.
      </p>
      <div class="flex items-center gap-6">
        {footerLinks.map((link) => (
          <a
            href={link.href}
            class="text-vault-muted hover:text-vault-text transition-colors text-sm"
          >
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </div>
</footer>
