---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import DifficultyBadge from '../../components/DifficultyBadge.astro';
import { toSlug } from '../../utils/slug';

export async function getStaticPaths() {
  return ['Easy', 'Medium', 'Hard'].map((level) => ({
    params: { level: level.toLowerCase() },
    props: { level },
  }));
}

const { level } = Astro.props;
const problems = await getCollection('problems');
const filtered = problems
  .filter((p) => p.data.difficulty === level)
  .sort((a, b) => a.data.number - b.data.number);
---

<BaseLayout title={`${level} Problems`} description={`All ${level} LeetCode problems — solutions with visual flow diagrams in Python and Java.`}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex items-center gap-3 mb-6">
      <h1 class="text-3xl font-bold text-vault-text">{level} Problems</h1>
      <DifficultyBadge difficulty={level as 'Easy' | 'Medium' | 'Hard'} />
    </div>
    <p class="text-vault-muted mb-8">{filtered.length} problem{filtered.length !== 1 ? 's' : ''}</p>

    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-vault-border text-left">
            <th class="py-3 px-2 text-vault-muted font-medium w-16">#</th>
            <th class="py-3 px-2 text-vault-muted font-medium">Problem</th>
            <th class="py-3 px-2 text-vault-muted font-medium hidden md:table-cell">Topics</th>
            <th class="py-3 px-2 text-vault-muted font-medium hidden lg:table-cell">Companies</th>
          </tr>
        </thead>
        <tbody>
          {filtered.map((problem) => (
            <tr class="border-b border-vault-border/50 hover:bg-vault-surface transition-colors">
              <td class="py-3 px-2 text-vault-muted">{problem.data.number}</td>
              <td class="py-3 px-2">
                <a href={`/problems/${problem.id}/`} class="text-vault-text hover:text-vault-primary transition-colors font-medium">
                  {problem.data.title}
                </a>
              </td>
              <td class="py-3 px-2 hidden md:table-cell">
                <div class="flex flex-wrap gap-1">
                  {problem.data.tags.map((tag) => (
                    <a href={`/topic/${toSlug(tag)}/`} class="text-xs px-1.5 py-0.5 rounded bg-vault-primary/10 text-vault-primary">
                      {tag}
                    </a>
                  ))}
                </div>
              </td>
              <td class="py-3 px-2 hidden lg:table-cell">
                <div class="flex flex-wrap gap-1">
                  {problem.data.companies.slice(0, 3).map((company) => (
                    <a href={`/company/${toSlug(company)}/`} class="text-xs text-vault-muted hover:text-vault-text">
                      {company}
                    </a>
                  ))}
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</BaseLayout>
