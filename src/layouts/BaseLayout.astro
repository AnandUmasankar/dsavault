---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { siteConfig, hasAdsense } from '../config/site';

interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
  ogType?: string;
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description = 'DSA Vault - LeetCode solutions with visual flow diagrams, brute force to optimal approach, in Python and Java.',
  canonicalUrl = Astro.url.href,
  ogType = 'website',
  jsonLd,
} = Astro.props;

const siteName = 'DSA Vault';
const fullTitle = title === siteName ? title : `${title} | ${siteName}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteName} />

    <!-- JSON-LD -->
    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {/* Google AdSense — loads automatically when adsenseId is set in src/config/site.ts */}
    {hasAdsense && (
      <script
        async
        src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${siteConfig.adsenseId}`}
        crossorigin="anonymous"
      />
    )}
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Growth Banner -->
    <div id="growth-banner" class="bg-vault-primary/10 border-b border-vault-primary/20 px-4 py-2.5 text-center relative">
      <p class="text-sm text-vault-text">
        <span class="text-vault-primary font-semibold">🚀 We're growing!</span>
        <span class="text-vault-muted"> — New problems added weekly. Bookmark us and check back often.</span>
      </p>
      <button id="close-banner" class="absolute right-3 top-1/2 -translate-y-1/2 text-vault-muted hover:text-vault-text text-lg leading-none" aria-label="Close banner">&times;</button>
    </div>
    <script>
      const banner = document.getElementById('growth-banner');
      const closeBtn = document.getElementById('close-banner');
      if (banner && closeBtn) {
        if (sessionStorage.getItem('banner-closed')) banner.style.display = 'none';
        closeBtn.addEventListener('click', () => {
          banner.style.display = 'none';
          sessionStorage.setItem('banner-closed', '1');
        });
      }
    </script>
    <Header />
    <main class="flex-grow">
      <slot />
    </main>
    <Footer />
  </body>
</html>
