---
import BaseLayout from './BaseLayout.astro';
import DifficultyBadge from '../components/DifficultyBadge.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import YouTubeEmbed from '../components/YouTubeEmbed.astro';
import AdPlacement from '../components/AdPlacement.astro';
import CompanyLogo from '../components/CompanyLogo.astro';

interface Props {
  frontmatter: {
    title: string;
    number: number;
    difficulty: 'Easy' | 'Medium' | 'Hard';
    tags: string[];
    companies: string[];
    youtube_url?: string;
    related_problems?: { title: string; slug: string }[];
    date_published: Date;
  };
}

const { frontmatter } = Astro.props;

import { toSlug } from '../utils/slug';

function extractYouTubeId(url: string): string | null {
  const match = url.match(/(?:youtu\.be\/|youtube\.com\/(?:watch\?v=|embed\/))([a-zA-Z0-9_-]{11})/);
  return match ? match[1] : null;
}

const videoId = frontmatter.youtube_url ? extractYouTubeId(frontmatter.youtube_url) : null;

const description = `LeetCode #${frontmatter.number} ${frontmatter.title} — ${frontmatter.difficulty} — Solution with visual flow diagram, brute force to optimal in Python and Java.`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: `${frontmatter.title} - LeetCode #${frontmatter.number}`,
  datePublished: frontmatter.date_published.toISOString(),
  description,
  author: { '@type': 'Organization', name: 'DSA Vault' },
  url: Astro.url.href,
};

const breadcrumbs = [
  { label: 'Home', href: '/' },
  ...(frontmatter.tags.length > 0
    ? [{ label: frontmatter.tags[0], href: `/topic/${toSlug(frontmatter.tags[0])}/` }]
    : []),
  { label: frontmatter.title },
];
---

<BaseLayout title={`${frontmatter.title} - LeetCode #${frontmatter.number}`} description={description} jsonLd={jsonLd} ogType="article">
  <article class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumbs items={breadcrumbs} />

    <!-- Metadata Bar -->
    <header class="mb-8">
      <h1 class="text-3xl sm:text-4xl font-bold text-vault-text mb-3">
        <span class="text-vault-muted font-normal">#{frontmatter.number}</span> {frontmatter.title}
      </h1>
      <div class="flex flex-wrap items-center gap-3">
        <DifficultyBadge difficulty={frontmatter.difficulty} />
        {frontmatter.tags.map((tag) => (
          <a href={`/topic/${toSlug(tag)}/`} class="text-xs px-2.5 py-1 rounded bg-vault-primary/10 text-vault-primary hover:bg-vault-primary/20 transition-colors">
            {tag}
          </a>
        ))}
      </div>
      {frontmatter.companies.length > 0 && (
        <div class="flex flex-wrap items-center gap-2 mt-3">
          <span class="text-xs text-vault-muted">Companies:</span>
          {frontmatter.companies.map((company) => (
            <a href={`/company/${toSlug(company)}/`} class="inline-flex items-center gap-1.5 text-xs px-2 py-1 rounded-lg bg-vault-surface text-vault-muted hover:text-vault-text border border-vault-border transition-all hover:border-vault-primary/40">
              <CompanyLogo company={company} size="sm" />
              {company}
            </a>
          ))}
        </div>
      )}
    </header>

    <!-- YouTube Timer CTA -->
    {frontmatter.youtube_url && (
      <div id="yt-timer-cta" class="mt-6 mb-8 relative overflow-hidden rounded-2xl border border-red-500/20 bg-gradient-to-r from-red-950/30 via-vault-surface to-red-950/20" data-yt-url={frontmatter.youtube_url}>
        <div class="relative z-10 px-5 py-5 sm:px-8 sm:py-6 flex flex-col sm:flex-row items-center gap-5">

          <!-- Circular Timer -->
          <div class="relative flex-shrink-0">
            <svg id="yt-ring" class="w-20 h-20 -rotate-90" viewBox="0 0 80 80">
              <circle cx="40" cy="40" r="34" fill="none" stroke="rgba(239,68,68,0.15)" stroke-width="5"/>
              <circle id="yt-ring-progress" cx="40" cy="40" r="34" fill="none" stroke="#ef4444" stroke-width="5" stroke-linecap="round" stroke-dasharray="213.628" stroke-dashoffset="213.628" style="transition: stroke-dashoffset 0.3s ease;"/>
            </svg>
            <div id="yt-timer-center" class="absolute inset-0 flex flex-col items-center justify-center">
              <span id="yt-countdown" class="text-2xl font-black text-red-400 tabular-nums">10</span>
              <span class="text-[9px] text-vault-muted uppercase tracking-widest">sec</span>
            </div>
          </div>

          <!-- Text Content -->
          <div class="flex-1 text-center sm:text-left">
            <div id="yt-locked-text">
              <p class="text-base sm:text-lg font-semibold text-vault-text">
                Brains first, video next. Unlocks in <span class="text-red-400 font-black" id="yt-inline-count">10</span>s
              </p>
            </div>
            <div id="yt-unlocked-text" class="hidden">
              <p class="text-base sm:text-lg font-semibold text-vault-text">
                Explanation video unlocked — watch now!
              </p>
            </div>
          </div>

          <!-- Button Area -->
          <div class="flex-shrink-0">
            <div id="yt-btn-locked" class="px-6 py-3 rounded-xl bg-vault-surface border border-vault-border text-vault-muted text-sm font-semibold cursor-not-allowed select-none flex items-center gap-2">
              <svg class="w-5 h-5 opacity-40" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
              ⏳ Drops soon...
            </div>
            <a
              id="yt-btn-unlocked"
              href={frontmatter.youtube_url}
              target="_blank"
              rel="noopener noreferrer"
              class="hidden yt-cta-btn group px-6 py-3 rounded-xl bg-red-600 hover:bg-red-500 text-white text-sm font-bold transition-all duration-300 hover:shadow-xl hover:shadow-red-600/30 hover:-translate-y-0.5 hover:scale-105 items-center gap-2"
            >
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
              See a Video Solution
              <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
            </a>
          </div>
        </div>
      </div>
    )}

    <AdPlacement slot="header" />

    <!-- Two-column layout: Content + Sidebar TOC -->
    <div class="lg:grid lg:grid-cols-[1fr_220px] lg:gap-8">

      <!-- Problem Content -->
      <div id="problem-content" class="prose prose-invert max-w-none
        prose-headings:text-vault-text
        prose-h2:text-2xl prose-h2:font-bold prose-h2:mt-10 prose-h2:mb-4 prose-h2:pb-0 prose-h2:border-0
        prose-h3:text-lg prose-h3:font-semibold prose-h3:mt-6 prose-h3:mb-3
        prose-p:text-vault-muted prose-p:leading-relaxed
        prose-a:text-vault-primary prose-a:no-underline hover:prose-a:underline
        prose-strong:text-vault-text
        prose-code:text-vault-primary prose-code:bg-vault-surface prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded
        prose-pre:bg-vault-surface prose-pre:border prose-pre:border-vault-border prose-pre:rounded-lg
        prose-li:text-vault-muted
        prose-hr:border-vault-border
      ">
        <slot />
      </div>

      <!-- Sticky Sidebar TOC (desktop only) -->
      <aside class="hidden lg:block">
        <nav id="toc" class="sticky top-24 text-sm space-y-1">
          <p class="text-vault-text font-semibold text-xs uppercase tracking-wider mb-3">On this page</p>
          <!-- TOC links populated by JS -->
        </nav>
      </aside>
    </div>

    <AdPlacement slot="after-content" />

    {frontmatter.related_problems && frontmatter.related_problems.length > 0 && (
      <section class="mt-10">
        <h2 class="text-2xl font-bold text-vault-text border-b border-vault-border pb-2 mb-4">Related Problems</h2>
        <div class="flex flex-wrap gap-3">
          {frontmatter.related_problems.map((rp) => (
            <a href={`/problems/${rp.slug}/`} class="inline-flex items-center gap-2 px-4 py-2.5 rounded-lg bg-vault-surface hover:bg-vault-surface-hover border border-vault-border hover:border-vault-primary/40 transition-all text-sm font-medium text-vault-text hover:text-vault-primary">
              <svg class="w-4 h-4 text-vault-muted" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/></svg>
              {rp.title}
            </a>
          ))}
        </div>
      </section>
    )}

    <AdPlacement slot="footer" />
  </article>
</BaseLayout>

<style is:global>
  /* ── Approach Section Cards ── */
  #problem-content h2 {
    scroll-margin-top: 6rem;
  }

  /* Wrap each h2 section in a visual card */
  .approach-card {
    border: 1px solid var(--color-vault-border);
    border-radius: 1rem;
    padding: 1.75rem;
    margin-top: 2rem;
    margin-bottom: 2rem;
    background: color-mix(in srgb, var(--color-vault-surface) 60%, transparent);
    position: relative;
    overflow: hidden;
  }

  /* Top accent bar */
  .approach-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
  }

  .approach-card.summary {
    border-color: color-mix(in srgb, var(--color-vault-primary) 30%, transparent);
    background: color-mix(in srgb, var(--color-vault-primary) 5%, var(--color-vault-surface));
  }
  .approach-card.summary::before {
    background: linear-gradient(90deg, var(--color-vault-primary), color-mix(in srgb, var(--color-vault-primary) 40%, transparent));
  }

  .approach-card.brute {
    border-left: 4px solid var(--color-vault-hard);
    border-color: color-mix(in srgb, var(--color-vault-hard) 25%, var(--color-vault-border));
    background: color-mix(in srgb, var(--color-vault-hard) 4%, var(--color-vault-surface));
  }
  .approach-card.brute::before {
    background: linear-gradient(90deg, var(--color-vault-hard), color-mix(in srgb, var(--color-vault-hard) 30%, transparent));
  }

  .approach-card.optimal {
    border-left: 4px solid var(--color-vault-easy);
    border-color: color-mix(in srgb, var(--color-vault-easy) 25%, var(--color-vault-border));
    background: color-mix(in srgb, var(--color-vault-easy) 4%, var(--color-vault-surface));
  }
  .approach-card.optimal::before {
    background: linear-gradient(90deg, var(--color-vault-easy), color-mix(in srgb, var(--color-vault-easy) 30%, transparent));
  }

  .approach-card.bridge {
    border-left: 4px solid var(--color-vault-medium);
    border-color: color-mix(in srgb, var(--color-vault-medium) 25%, var(--color-vault-border));
    background: color-mix(in srgb, var(--color-vault-medium) 5%, var(--color-vault-surface));
  }
  .approach-card.bridge::before {
    background: linear-gradient(90deg, var(--color-vault-medium), color-mix(in srgb, var(--color-vault-medium) 30%, transparent));
  }

  /* ── Section Toggle Header ── */
  .section-toggle {
    display: flex;
    align-items: center;
    justify-content: space-between;
    cursor: pointer;
    user-select: none;
    padding: 0.25rem 0;
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-vault-text);
    line-height: 1.3;
  }

  .section-toggle .chevron {
    transition: transform 0.2s ease;
    color: var(--color-vault-muted);
    flex-shrink: 0;
    margin-left: 0.75rem;
  }

  .section-toggle.collapsed .chevron {
    transform: rotate(-90deg);
  }

  .section-body.hidden {
    display: none;
  }

  /* ── Approach Label Pill ── */
  .approach-label {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    margin-bottom: 0.75rem;
  }

  .approach-label.brute {
    background: color-mix(in srgb, var(--color-vault-hard) 15%, transparent);
    color: var(--color-vault-hard);
  }

  .approach-label.optimal {
    background: color-mix(in srgb, var(--color-vault-easy) 15%, transparent);
    color: var(--color-vault-easy);
  }

  .approach-label.bridge {
    background: color-mix(in srgb, var(--color-vault-medium) 15%, transparent);
    color: var(--color-vault-medium);
  }

  .approach-label.summary {
    background: color-mix(in srgb, var(--color-vault-primary) 15%, transparent);
    color: var(--color-vault-primary);
  }

  /* ── Language Tabs ── */
  .lang-tabs {
    display: flex;
    gap: 0;
    border-bottom: 1px solid var(--color-vault-border);
    margin-bottom: 0;
  }

  .lang-tab {
    padding: 0.4rem 1rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-vault-muted);
    cursor: pointer;
    border-bottom: 2px solid transparent;
    transition: all 0.15s ease;
    background: none;
    border-top: none;
    border-left: none;
    border-right: none;
  }

  .lang-tab:hover {
    color: var(--color-vault-text);
  }

  .lang-tab.active {
    color: var(--color-vault-primary);
    border-bottom-color: var(--color-vault-primary);
  }

  .lang-panel {
    display: none;
  }

  .lang-panel.active {
    display: block;
  }

  /* ── Compact Mermaid Diagrams ── */
  #problem-content svg.flowchart,
  #problem-content svg[id^="mermaid-"] {
    max-height: 350px;
    width: auto;
    margin: 0 auto;
    display: block;
  }

  /* Mermaid click-to-expand wrapper */
  .mermaid-expandable {
    position: relative;
    cursor: pointer;
    border: 1px solid var(--color-vault-border);
    border-radius: 0.75rem;
    padding: 1rem;
    transition: border-color 0.2s;
    overflow: hidden;
  }

  .mermaid-expandable:hover {
    border-color: var(--color-vault-primary);
  }

  .mermaid-expand-hint {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.65rem;
    font-weight: 500;
    color: var(--color-vault-muted);
    background: var(--color-vault-surface);
    border: 1px solid var(--color-vault-border);
    padding: 0.25rem 0.6rem;
    border-radius: 0.375rem;
    opacity: 0;
    transition: opacity 0.2s;
    pointer-events: none;
    z-index: 2;
  }

  .mermaid-expandable:hover .mermaid-expand-hint {
    opacity: 1;
  }

  /* ── Lightbox overlay ── */
  .diagram-lightbox {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(0, 0, 0, 0.9);
    backdrop-filter: blur(6px);
    display: none;
    flex-direction: column;
  }

  .diagram-lightbox.open {
    display: flex;
  }

  .diagram-lightbox-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.6rem 1.25rem;
    background: rgba(15, 23, 42, 0.95);
    border-bottom: 1px solid var(--color-vault-border);
    flex-shrink: 0;
  }

  .diagram-lightbox-toolbar .hint-text {
    font-size: 0.7rem;
    color: var(--color-vault-muted);
  }

  .diagram-lightbox-toolbar button {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.75rem;
    padding: 0.4rem 0.85rem;
    border-radius: 0.375rem;
    border: 1px solid var(--color-vault-border);
    background: var(--color-vault-surface);
    color: var(--color-vault-muted);
    cursor: pointer;
    transition: all 0.15s;
  }

  .diagram-lightbox-toolbar button:hover {
    background: var(--color-vault-surface-hover);
    color: var(--color-vault-text);
  }

  .diagram-lightbox-toolbar button.close-btn {
    background: rgba(239, 68, 68, 0.15);
    border-color: rgba(239, 68, 68, 0.4);
    color: #EF4444;
  }

  .diagram-lightbox-toolbar button.close-btn:hover {
    background: rgba(239, 68, 68, 0.3);
    color: #FCA5A5;
  }

  .diagram-lightbox-viewport {
    flex: 1;
    overflow: hidden;
    cursor: crosshair;
    position: relative;
  }

  .diagram-lightbox-canvas {
    position: absolute;
    top: 0;
    left: 0;
    transform-origin: 0 0;
    will-change: transform;
    transition: transform 0.08s ease-out;
  }

  .diagram-lightbox-canvas svg {
    max-height: none !important;
    max-width: none !important;
    width: auto;
    height: auto;
  }

  /* Complexity badges */
  .complexity-bar {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }

  .complexity-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.75rem;
    padding: 0.3rem 0.75rem;
    border-radius: 0.5rem;
    background: var(--color-vault-surface);
    border: 1px solid var(--color-vault-border);
    color: var(--color-vault-muted);
  }

  .complexity-chip strong {
    color: var(--color-vault-text);
  }

  /* ── TOC Sidebar ── */
  #toc a {
    display: block;
    padding: 0.3rem 0.75rem;
    color: var(--color-vault-muted);
    text-decoration: none;
    border-left: 2px solid transparent;
    transition: all 0.15s ease;
    font-size: 0.8rem;
    line-height: 1.4;
  }

  #toc a:hover {
    color: var(--color-vault-text);
  }

  #toc a.active {
    color: var(--color-vault-primary);
    border-left-color: var(--color-vault-primary);
    font-weight: 500;
  }

  #toc a.toc-h3 {
    padding-left: 1.25rem;
    font-size: 0.75rem;
  }

  /* ── YouTube Timer CTA ── */
  @keyframes yt-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.4); }
    50% { box-shadow: 0 0 0 10px rgba(239, 68, 68, 0); }
  }

  .yt-cta-btn {
    animation: yt-pulse 2s ease-in-out infinite;
  }
  .yt-cta-btn:hover {
    animation: none;
  }
</style>

<script>
  function enhanceProblemPage() {
    const content = document.getElementById('problem-content');
    if (!content) return;

    // ── 1. Wrap sections in approach cards ──
    const h2s = content.querySelectorAll('h2');
    h2s.forEach((h2) => {
      const text = h2.textContent?.toLowerCase() || '';
      let cardType = '';
      let labelText = '';
      let icon = '';

      if (text.includes('approach 1') || text.includes('brute')) {
        cardType = 'brute';
        labelText = 'Brute Force';
        icon = '🐢';
      } else if (text.includes('approach 2') || text.includes('optimal')) {
        cardType = 'optimal';
        labelText = 'Optimal Solution';
        icon = '⚡';
      } else if (text.includes('why') || text.includes('good enough')) {
        cardType = 'bridge';
        labelText = 'Key Insight';
        icon = '💡';
      } else if (text.includes('problem summary') || text.includes('problem statement')) {
        cardType = 'summary';
        labelText = 'Problem';
        icon = '📋';
      }

      if (!cardType) return;

      // Collect all siblings until next h2 or end
      const siblings = [];
      let el = h2.nextElementSibling;
      while (el && el.tagName !== 'H2') {
        siblings.push(el);
        el = el.nextElementSibling;
      }

      // Create the card wrapper
      const card = document.createElement('div');
      card.className = `approach-card ${cardType}`;

      // Add label pill
      const label = document.createElement('div');
      label.className = `approach-label ${cardType}`;
      label.innerHTML = `${icon} ${labelText}`;
      card.appendChild(label);

      // Make h2 a collapsible toggle
      const toggle = document.createElement('div');
      toggle.className = 'section-toggle';
      toggle.innerHTML = `<span>${h2.innerHTML}</span><svg class="chevron w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>`;

      // Keep h2 id for scroll linking
      const h2Id = h2.id || text.replace(/[^a-z0-9]+/g, '-').replace(/-+$/, '');
      h2.id = h2Id;
      toggle.id = h2Id + '-toggle';

      const body = document.createElement('div');
      body.className = 'section-body';
      siblings.forEach((s) => body.appendChild(s));

      toggle.addEventListener('click', () => {
        toggle.classList.toggle('collapsed');
        body.classList.toggle('hidden');
      });

      card.appendChild(toggle);
      card.appendChild(body);

      // Replace h2 with card
      h2.replaceWith(card);
    });

    // ── 2. Language tab switcher for code blocks ──
    const cards = content.querySelectorAll('.approach-card');
    cards.forEach((card) => {
      const h3s = card.querySelectorAll('h3');
      const langGroups = [];
      let currentGroup: { label: string; heading: Element; codeWrapper: Element | null }[] = [];

      h3s.forEach((h3) => {
        const title = h3.textContent?.trim() || '';
        // Detect language headings: "Python Solution", "Java Solution", "Python", "Java"  
        const langMatch = title.match(/^(Python|Java)/i);
        if (langMatch) {
          const nextEl = h3.nextElementSibling;
          // The code block might be wrapped in a .relative.group div by the copy button script
          const codeWrapper = nextEl?.tagName === 'DIV' && nextEl.querySelector('pre')
            ? nextEl
            : nextEl?.tagName === 'PRE' ? nextEl : null;
          currentGroup.push({ label: langMatch[1], heading: h3, codeWrapper });
        } else {
          if (currentGroup.length >= 2) langGroups.push([...currentGroup]);
          currentGroup = [];
        }
      });
      if (currentGroup.length >= 2) langGroups.push([...currentGroup]);

      langGroups.forEach((group) => {
        const tabBar = document.createElement('div');
        tabBar.className = 'lang-tabs';

        const panels: Element[] = [];

        group.forEach((item, idx) => {
          const tab = document.createElement('button');
          tab.className = `lang-tab${idx === 0 ? ' active' : ''}`;
          tab.textContent = item.label;
          tab.setAttribute('data-lang-idx', String(idx));
          tabBar.appendChild(tab);

          // Create panel wrapping the code
          const panel = document.createElement('div');
          panel.className = `lang-panel${idx === 0 ? ' active' : ''}`;
          if (item.codeWrapper) panel.appendChild(item.codeWrapper);
          panels.push(panel);

          // Hide the h3 heading
          (item.heading as HTMLElement).style.display = 'none';
        });

        // Tab click handler
        tabBar.addEventListener('click', (e) => {
          const target = e.target as HTMLElement;
          if (!target.classList.contains('lang-tab')) return;
          const idx = parseInt(target.getAttribute('data-lang-idx') || '0');
          tabBar.querySelectorAll('.lang-tab').forEach((t) => t.classList.remove('active'));
          target.classList.add('active');
          panels.forEach((p, i) => p.classList.toggle('active', i === idx));
        });

        // Insert before first heading in this group
        group[0].heading.before(tabBar);
        panels.forEach((p) => tabBar.after(p));
        // Reverse insert order
        for (let i = panels.length - 1; i >= 0; i--) {
          tabBar.after(panels[i]);
        }
      });
    });

    // ── 3. Convert complexity text to chips ──
    content.querySelectorAll('p').forEach((p) => {
      const text = p.textContent || '';
      if (!text.includes('Time:') || !text.includes('Space:')) return;

      const timeMatch = text.match(/Time:\s*(O\([^)]+\))/);
      const spaceMatch = text.match(/Space:\s*(O\([^)]+\))/);
      if (!timeMatch || !spaceMatch) return;

      const bar = document.createElement('div');
      bar.className = 'complexity-bar';

      const timeDesc = text.match(/Time:\s*O\([^)]+\)\s*[—–-]\s*(.+?)(?:\s*\||\s*$)/)?.[1] || '';
      const spaceDesc = text.match(/Space:\s*O\([^)]+\)\s*[—–-]\s*(.+?)$/)?.[1] || '';

      bar.innerHTML = `
        <div class="complexity-chip">⏱ <strong>${timeMatch[1]}</strong>${timeDesc ? ` — ${timeDesc}` : ''}</div>
        <div class="complexity-chip">💾 <strong>${spaceMatch[1]}</strong>${spaceDesc ? ` — ${spaceDesc}` : ''}</div>
      `;
      p.replaceWith(bar);
    });

    // ── 4. Build TOC sidebar ──
    const toc = document.getElementById('toc');
    if (toc) {
      const headings = content.querySelectorAll('.section-toggle[id], h2[id], h3[id]');
      // Also grab approach cards for their toggle IDs
      const tocItems: { id: string; text: string; level: string }[] = [];

      content.querySelectorAll('.approach-card').forEach((card) => {
        const toggle = card.querySelector('.section-toggle');
        if (toggle?.id) {
          tocItems.push({ id: toggle.id, text: toggle.querySelector('span')?.textContent?.trim() || '', level: 'h2' });
        }
      });

      // Also grab standalone h2s that weren't wrapped in cards (like Problem Summary)
      content.querySelectorAll('h2[id]').forEach((h2) => {
        tocItems.push({ id: h2.id, text: h2.textContent?.trim() || '', level: 'h2' });
      });

      tocItems.forEach(({ id, text, level }) => {
        const a = document.createElement('a');
        a.href = `#${id}`;
        a.textContent = text;
        if (level === 'h3') a.classList.add('toc-h3');
        a.addEventListener('click', (e) => {
          e.preventDefault();
          document.getElementById(id)?.scrollIntoView({ behavior: 'smooth' });
        });
        toc.appendChild(a);
      });

      // Intersection observer for active state
      if (tocItems.length > 0) {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              const id = entry.target.id;
              const link = toc.querySelector(`a[href="#${id}"]`);
              if (entry.isIntersecting) {
                toc.querySelectorAll('a').forEach((a) => a.classList.remove('active'));
                link?.classList.add('active');
              }
            });
          },
          { rootMargin: '-80px 0px -60% 0px' }
        );

        tocItems.forEach(({ id }) => {
          const el = document.getElementById(id);
          if (el) observer.observe(el);
        });
      }
    }
  }

  // ── Copy buttons (must run before enhance so code blocks are in place) ──
  document.querySelectorAll('#problem-content pre:not([class*="mermaid"])').forEach((pre) => {
    // Skip mermaid code blocks
    if (pre.getAttribute('data-language') === 'mermaid') return;

    const wrapper = document.createElement('div');
    wrapper.className = 'relative group';
    pre.parentNode?.insertBefore(wrapper, pre);
    wrapper.appendChild(pre);

    const btn = document.createElement('button');
    btn.className = 'absolute top-2 right-2 px-2 py-1 text-xs rounded bg-vault-surface-hover text-vault-muted hover:text-vault-text opacity-0 group-hover:opacity-100 transition-opacity';
    btn.textContent = 'Copy';
    btn.addEventListener('click', () => {
      const code = pre.querySelector('code');
      if (code) {
        navigator.clipboard.writeText(code.textContent || '');
        btn.textContent = 'Copied!';
        setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
      }
    });
    wrapper.appendChild(btn);
  });

  // ── Client-side Mermaid Rendering ──
  async function renderMermaidDiagrams() {
    const content = document.getElementById('problem-content');
    if (!content) return;

    // Find Shiki-rendered mermaid code blocks
    const mermaidBlocks = content.querySelectorAll('pre[data-language="mermaid"]');
    if (mermaidBlocks.length === 0) return;

    // Load Mermaid from CDN
    const { default: mermaid } = await import('https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs');
    mermaid.initialize({
      startOnLoad: false,
      theme: 'dark',
      themeVariables: {
        primaryColor: '#1e3a5f',
        primaryBorderColor: '#3B82F6',
        primaryTextColor: '#E2E8F0',
        lineColor: '#94A3B8',
        secondaryColor: '#1a2540',
        tertiaryColor: '#131C31',
        fontFamily: 'ui-sans-serif, system-ui, sans-serif',
      },
    });

    // Convert each Shiki code block to a mermaid-rendered SVG
    for (let i = 0; i < mermaidBlocks.length; i++) {
      const pre = mermaidBlocks[i];
      const code = pre.querySelector('code');
      if (!code) continue;

      // Extract the raw mermaid text (strip Shiki spans)
      const mermaidCode = code.textContent || '';
      const id = `mermaid-${i}`;

      try {
        const { svg } = await mermaid.render(id, mermaidCode.trim());
        const container = document.createElement('div');
        container.innerHTML = svg;
        pre.replaceWith(container.firstElementChild!);
      } catch {
        // Leave the code block as-is if rendering fails
      }
    }
  }

  // Run mermaid first, then enhance page and init lightbox
  renderMermaidDiagrams().then(() => {
    enhanceProblemPage();
    initDiagramLightbox();
  });

  // ── 6. Mermaid Lightbox — cursor-follow panning ──
  function initDiagramLightbox() {
    const lightbox = document.createElement('div');
    lightbox.className = 'diagram-lightbox';
    lightbox.innerHTML = `
      <div class="diagram-lightbox-toolbar">
        <span class="hint-text">Move cursor to navigate</span>
        <div style="display:flex;gap:0.4rem;align-items:center">
          <button data-action="zoom-out">− Zoom Out</button>
          <button data-action="zoom-in">+ Zoom In</button>
          <button data-action="close" class="close-btn">✕ Close</button>
        </div>
      </div>
      <div class="diagram-lightbox-viewport">
        <div class="diagram-lightbox-canvas"></div>
      </div>
    `;
    document.body.appendChild(lightbox);

    const viewport = lightbox.querySelector('.diagram-lightbox-viewport') as HTMLElement;
    const canvas = lightbox.querySelector('.diagram-lightbox-canvas') as HTMLElement;
    let svgW = 0;
    let svgH = 0;
    let zoom = 1.6; // start a bit zoomed out so more is visible

    function applyTransformAtCursor(mx: number, my: number, vw: number, vh: number) {
      const totalW = svgW * zoom;
      const totalH = svgH * zoom;
      const overflowX = totalW - vw;
      const overflowY = totalH - vh;
      // Amplify cursor position for higher sensitivity (1.3x)
      const sx = Math.max(0, Math.min(1, (mx - 0.5) * 1.3 + 0.5));
      const sy = Math.max(0, Math.min(1, (my - 0.5) * 1.3 + 0.5));
      const x = overflowX > 0 ? -overflowX * sx : (vw - totalW) / 2;
      const y = overflowY > 0 ? -overflowY * sy : (vh - totalH) / 2;
      canvas.style.transform = `translate(${x}px, ${y}px) scale(${zoom})`;
    }

    let lastMx = 0.5;
    let lastMy = 0.5;

    function openLightbox(svgEl: SVGElement) {
      const clone = svgEl.cloneNode(true) as SVGElement;
      const vb = clone.getAttribute('viewBox');
      if (vb) {
        const parts = vb.split(/\s+/);
        if (parts.length === 4) {
          clone.setAttribute('width', parts[2]);
          clone.setAttribute('height', parts[3]);
        }
      }
      clone.removeAttribute('style');
      clone.style.display = 'block';
      canvas.innerHTML = '';
      canvas.appendChild(clone);
      canvas.style.transform = `scale(${zoom})`;

      lightbox.classList.add('open');
      document.body.style.overflow = 'hidden';

      requestAnimationFrame(() => {
        svgW = clone.getBoundingClientRect().width / zoom;
        svgH = clone.getBoundingClientRect().height / zoom;
        const vw = viewport.clientWidth;
        const vh = viewport.clientHeight;
        // Start centered
        lastMx = 0.5;
        lastMy = 0.5;
        applyTransformAtCursor(0.5, 0.5, vw, vh);
      });
    }

    function closeLightbox() {
      lightbox.classList.remove('open');
      document.body.style.overflow = '';
      canvas.innerHTML = '';
    }

    // Cursor position directly controls panning — no dragging needed
    viewport.addEventListener('mousemove', (e) => {
      if (!lightbox.classList.contains('open')) return;
      const rect = viewport.getBoundingClientRect();
      lastMx = (e.clientX - rect.left) / rect.width;
      lastMy = (e.clientY - rect.top) / rect.height;
      applyTransformAtCursor(lastMx, lastMy, rect.width, rect.height);
    });

    // Click viewport to close
    viewport.addEventListener('click', () => closeLightbox());

    // Toolbar buttons
    lightbox.querySelectorAll('button[data-action]').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const action = btn.getAttribute('data-action');
        if (action === 'close') { closeLightbox(); return; }
        if (action === 'zoom-in') zoom = Math.min(zoom + 0.3, 5);
        if (action === 'zoom-out') zoom = Math.max(zoom - 0.3, 0.5);
        const rect = viewport.getBoundingClientRect();
        applyTransformAtCursor(lastMx, lastMy, rect.width, rect.height);
      });
    });

    // Escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && lightbox.classList.contains('open')) closeLightbox();
    });

    // Wrap each mermaid SVG with expandable hint
    document.querySelectorAll('#problem-content svg[id^="mermaid-"]').forEach((svg) => {
      const wrapper = document.createElement('div');
      wrapper.className = 'mermaid-expandable';
      const hint = document.createElement('div');
      hint.className = 'mermaid-expand-hint';
      hint.innerHTML = '🔍 Click to expand';
      svg.parentNode?.insertBefore(wrapper, svg);
      wrapper.appendChild(hint);
      wrapper.appendChild(svg);
      wrapper.addEventListener('click', (e) => {
        e.stopPropagation();
        openLightbox(svg as SVGElement);
      });
    });
  }

  // ── YouTube Timer Countdown ──
  (function initYtTimer() {
    const cta = document.getElementById('yt-timer-cta');
    if (!cta) return;

    const countdown = document.getElementById('yt-countdown');
    const ringProgress = document.getElementById('yt-ring-progress');
    const lockedText = document.getElementById('yt-locked-text');
    const unlockedText = document.getElementById('yt-unlocked-text');
    const btnLocked = document.getElementById('yt-btn-locked');
    const btnUnlocked = document.getElementById('yt-btn-unlocked');
    const timerCenter = document.getElementById('yt-timer-center');

    if (!countdown || !ringProgress || !lockedText || !unlockedText || !btnLocked || !btnUnlocked) return;

    const TOTAL = 10;
    const CIRCUMFERENCE = 2 * Math.PI * 34; // matches r=34 in SVG
    let remaining = TOTAL;

    const interval = setInterval(() => {
      remaining--;
      countdown.textContent = String(remaining);

      // Sync inline count in the text
      const inlineCount = document.getElementById('yt-inline-count');
      if (inlineCount) inlineCount.textContent = String(remaining);

      // Fill ring progressively
      const progress = (TOTAL - remaining) / TOTAL;
      ringProgress.style.strokeDashoffset = String(CIRCUMFERENCE * (1 - progress));

      if (remaining <= 0) {
        clearInterval(interval);
        unlock();
      }
    }, 1000);

    function unlock() {
      // Swap texts
      lockedText.classList.add('hidden');
      unlockedText.classList.remove('hidden');

      // Swap buttons
      btnLocked.classList.add('hidden');
      btnUnlocked.classList.remove('hidden');
      btnUnlocked.classList.add('inline-flex');

      // Timer center shows play emoji
      if (timerCenter) {
        timerCenter.innerHTML = '<span class="text-3xl">&#9654;&#65039;</span>';
      }

      // Change ring color to green
      ringProgress.style.stroke = '#4ade80';

      // Change border & bg to green tint
      cta.classList.remove('border-red-500/20', 'from-red-950/30', 'to-red-950/20');
      cta.classList.add('border-green-500/30', 'from-green-950/30', 'to-green-950/20');

      // Bounce the button
      btnUnlocked.animate([
        { transform: 'scale(1)' },
        { transform: 'scale(1.12)' },
        { transform: 'scale(1)' },
      ], { duration: 500, easing: 'ease-out' });
    }
  })();
</script>
